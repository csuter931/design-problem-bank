rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Config: authenticated users can read (for superuser check), no client writes
    match /config/{document} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Problems: public read/create; update allowed if unauthenticated only when not touching internalNotes
    match /problems/{problemId} {
      allow read, create: if true;
      allow update: if request.auth != null ||
        !('internalNotes' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if request.auth != null;
    }

    // Teams: any authenticated user can read (needed for team list / manage teams)
    // Write/delete restricted to own document only
    match /teams/{userId} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null && request.auth.uid == userId;
    }

  }
}
